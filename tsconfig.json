{
  "compilerOptions": {
    "module": "ESNext",
    "target": "es2019",
    "lib": ["dom", "es2019"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "types": ["node", "react"],
    "typeRoots": ["./node_modules/@types", "./node_modules"],
    "strict": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "publish"]
}
